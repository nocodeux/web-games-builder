# Web Games Builder — environment variables
# Copy this file to .env and fill in your values.

PORT=3002
NODE_ENV=development
CORS_ORIGINS=http://localhost:3001

# PostgreSQL (optional — filesystem fallback used if not set)
DATABASE_URL=postgresql://user:password@localhost:5432/web_games_builder

# Auth
JWT_SECRET=generate-with-node-e-console-log-require-crypto-randomBytes-32-toString-hex

# File storage
STORAGE_DRIVER=local
STORAGE_PATH=./uploads

# S3 (optional — used when STORAGE_DRIVER=s3)
AWS_ENDPOINT_URL=
AWS_BUCKET=web-games-builder-assets
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CDN_BASE_URL=

# Admin account (created on first server start)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
